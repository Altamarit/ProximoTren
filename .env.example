# ─────────────────────────────────────────────────────────────────────────────
# Próximo Metro — Variables de Entorno
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subas .env.local ni ningún archivo con secretos al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
# Valores: development | staging | production
NODE_ENV=development

# ── CRTM API ─────────────────────────────────────────────────────────────────
# URL base de la API oficial de CRTM (sin slash final)
CRTM_API_BASE_URL=https://api.crtm.es/v1

# Timeout en milisegundos para peticiones al CRTM (5000 = 5s, según ADR)
CRTM_API_TIMEOUT_MS=5000

# ── Modo de adaptador ────────────────────────────────────────────────────────
# "live"  → CRTMAdapter (datos reales, requiere red y credenciales)
# "mock"  → MockAdapter (datos sintéticos, sin red, para demo offline)
TRANSPORT_ADAPTER=mock

# ── Logtail / Observabilidad ─────────────────────────────────────────────────
# Source token de Logtail EU (Better Stack). Obtener en:
# https://logs.betterstack.com → Sources → New source → región EU
LOGTAIL_SOURCE_TOKEN=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Máximo de peticiones por IP por minuto al endpoint /api/times
RATE_LIMIT_MAX_RPM=60

# ── Caché in-memory ───────────────────────────────────────────────────────────
# Ventana de caché en segundos (30 = 30s, según ADR)
CACHE_TTL_SECONDS=30
